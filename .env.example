# ─────────────────────────────────────────────
# MASAR — Environment Variables
# انسخ هذا الملف إلى .env.local وعبّئ القيم
# ─────────────────────────────────────────────

# [مطلوب] مفتاح Gemini AI من Google AI Studio
GEMINI_API_KEY="your_gemini_api_key_here"

# [مطلوب في production] مفتاح JWT — يجب أن يكون عشوائيًا وطويلًا (32+ حرف)
# لتوليد قيمة: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="generate_a_strong_random_secret_here"

# [مطلوب في production] عنوان الفرونت إند للسماح به في CORS
FRONTEND_URL="https://your-domain.com"

# [اختياري] عنوان التطبيق الكامل
APP_URL="https://your-domain.com"

# [اختياري] رمز بوت تليجرام
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# [مطلوب] إيميلات الأدمن مفصولة بفاصلة — هم فقط يصلون /api/admin/*
ADMIN_EMAILS="admin@your-domain.com,you@example.com"

# بيئة التشغيل: development | production
NODE_ENV="development"

# المنفذ (اختياري — الافتراضي 3000)
# PORT=3000
